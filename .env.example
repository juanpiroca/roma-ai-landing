# Roma — Variables de entorno
# Copia este archivo a .env y completa los valores

# Telegram Bot (obtener en @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_personal_chat_id

# OpenAI (para transcripción de voz con Whisper)
OPENAI_API_KEY=your_openai_key

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_key

# Email (Gmail — usa App Password, no la contraseña normal)
GMAIL_USER=your@gmail.com
GMAIL_PASS=your_app_password_16chars

# Siri/Alexa security token (inventar un string secreto)
ROMA_SECRET=change_this_to_a_random_secret_string

# Google Drive (opcional — OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Tu usuario autorizado (chat_id de Telegram)
ALLOWED_CHAT_ID=your_telegram_chat_id

# n8n
N8N_BASE_URL=https://n8n.combonix.com
N8N_API_KEY=

# Prospección avanzada
APIFY_TOKEN=
APIFY_GOOGLE_MAPS_ACTOR_ID=
